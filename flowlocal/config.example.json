{
  "hotkey": "ctrl_r",
  "hotkey_mode": "hold",

  "model": "base.en",
  "device": "auto",
  "compute_type": "auto",
  "language": "en",
  "vad_filter": true,
  "vocabulary": ["Kubernetes", "Anthropic", "Jesse"],

  "insert_mode": "paste",
